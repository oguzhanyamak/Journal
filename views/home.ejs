<% const categories=Object.entries(categorizedNews); %>

    <div class="flex jc-even gap-2">
        <div class="flex gap-4 ai-stretch">
            <!-- Ana Slider -->
            <div class="slider-container">
                <div class="carousel">
                    <% if (categorizedNews.SonDakika && categorizedNews.SonDakika.length> 0) { %>
                        <% categorizedNews.SonDakika.forEach(newsItem=> { %>
                            <div class="slide">
                                <a class="bridge" href="<%= newsItem.link%>" target="_blank">
                                    <div class="slide-image-wrapper">
                                        <img src="<%= newsItem.image_url || '/images/sd.png' %>"
                                            alt="<%= newsItem.title %>">
                                        <div class="image-overlay"></div>
                                    </div>
                                    <div class="slide-content">
                                        <h3>
                                            <%= newsItem.title %>
                                        </h3>
                                        <div class="news-info">
                                            <span><i class="fas fa-newspaper"></i>
                                                <%= newsItem.provider %>
                                            </span>
                                            <span><i class="fas fa-clock"></i>
                                                <%= new Date(newsItem.published_dt).toLocaleDateString() %>
                                            </span>
                                        </div>
                                    </div>
                                </a>
                            </div>
                            <% }) %>
                                <% } %>
                </div>
                <button class="nav prev">❮</button>
                <button class="nav next">❯</button>
            </div>

            <!-- Gündem Haberleri -->
            <div class="gundem-container">
                <div class="gundem-grid">
                    <% categories.forEach(([category, newsList])=> { %>
                        <% if (category==="Gündem" ) { %>
                            <% newsList.slice(0, 3).forEach(newsItem=> { %>
                                <article class="gundem-card">

                                    <img class="news-image" src="<%= newsItem.image_url%>" alt="<%= newsItem.title %>"
                                        data-category="<%= newsItem.category %>">
                                    <div class="card-content">
                                        <h3>
                                            <%= newsItem.title %>
                                        </h3>
                                        <div class="news-meta">
                                            <h4>
                                                <%= newsItem.provider || "Bilinmiyor" %>
                                            </h4>
                                            <h4>•</h4>
                                            <h4>
                                                <%= new Date(newsItem.published_dt).toLocaleDateString() %>
                                            </h4>
                                        </div>
                                    </div>
                                </article>
                                <% }) %>
                                    <% } %>
                                        <% }) %>
                </div>
            </div>
        </div>
    </div>

    <div class="categories-container">
        <% categories.forEach(([category, newsList])=> { %>
            <% if (category !=="SonDakika" && category !=="Gündem" ) { %>
                <section class="category-section">
                    <div class="section-header mt-4">
                        <h2 class="category-title">
                            <%= category %>
                        </h2>
                        <div class="flex-grow-line"></div>
                        <a href="/<%= category.toLowerCase() %>" class="see-more">Daha Fazla →</a>
                    </div>
                    <div class="news-grid">
                        <% newsList.forEach(newsItem=> { %>
                            <article class="news-card">
                                <a class="bridge" href="<%= newsItem.link %>" target="_blank">
                                    <img class="news-image" src="<%= newsItem.image_url%>" alt="<%= newsItem.title %>"
                                        data-category="<%= newsItem.category %>">
                                    <div class="card-content1">
                                        <div class="news-meta">
                                            <span>
                                                <%= newsItem.provider %>
                                            </span>
                                            <span>•</span>
                                            <span>
                                                <%= new Date(newsItem.published_dt).toLocaleDateString() %>
                                            </span>
                                        </div>
                                        <h3>
                                            <%= newsItem.title %>
                                        </h3>
                                        <p>
                                            <%= (newsItem.content || "Açıklama yok." ).substring(0, 100) + "..." %>
                                        </p>
                                        <div class="card-footer">
                                            <a href="<%= newsItem.link %>" target="_blank" class="read-more-btn">
                                                Devamını Oku
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                    xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round"
                                                        stroke-linejoin="round" />
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                </a>
                            </article>
                            <% }) %>
                    </div>
                </section>
                <% } %>
                    <% }) %>
    </div>