<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Finansal Semboller</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f9;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .container {
            width: 90%;
            max-width: 600px;
            background-color: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            text-align: center;
        }

        h1 {
            color: #333;
        }

        .symbol-list {
            margin-top: 20px;
            text-align: left;
            list-style-type: none;
            padding: 0;
        }

        .symbol-item {
            padding: 10px;
            margin-bottom: 10px;
            background-color: #f9f9f9;
            border-radius: 5px;
            border: 1px solid #ddd;
        }

        .symbol-item strong {
            color: #0056b3;
        }

        .symbol-item span {
            font-size: 14px;
            color: #555;
        }

        .loading {
            font-size: 18px;
            color: #888;
        }

        .error {
            color: red;
            font-size: 16px;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>
<body>

<div class="container">
    <h1>Finansal Semboller</h1>
    <ul id="symbol-list" class="symbol-list">
        <!-- Listeler burada dinamik olarak yüklenecek -->
    </ul>
    <div id="loading-message" class="loading">Veriler yükleniyor...</div>
    <div id="error-message" class="error"></div>
</div>

<script>
    const SYMBOLS = [
        { "description": "BIST 100", "proName": "XU100.IS" },  // Yahoo Finance sembolü
        { "description": "GRAM ALTIN", "proName": "XAUUSD=X" },
        { "description": "DOLAR / TL", "proName": "USDTRY=X" },
        { "description": "EURO / TL", "proName": "EURTRY=X" }
    ];

    // Yahoo Finance API endpoint URL
    const API_URL = "https://query1.finance.yahoo.com/v8/finance/chart/";

    function fetchData(symbol) {
        const url = `${API_URL}${symbol.proName}`;

        return axios.get(url)
            .then(response => {
                // Veriyi kontrol et
                console.log(response.data);
                return response.data.chart.result[0]; // Çekilen veriyi döndür
            })
            .catch(error => {
                throw new Error('Veri alınırken hata oluştu: ' + error);
            });
    }

    // Listeyi güncelleme fonksiyonu
    function updateSymbolList(symbols) {
        const listContainer = document.getElementById("symbol-list");
        const loadingMessage = document.getElementById("loading-message");
        const errorMessage = document.getElementById("error-message");

        // Yükleme mesajını kaldırıyoruz
        loadingMessage.style.display = 'none';

        // Listeyi temizle
        listContainer.innerHTML = '';

        // Her sembol için veri çekme ve liste oluşturma
        symbols.forEach(symbol => {
            fetchData(symbol).then(data => {
                // En son veriyi alıyoruz
                const latestData = data.indicators.quote[0]; // Son verileri al

                if (!latestData) {
                    errorMessage.textContent = `Veri alınamadı: ${symbol.description}`;
                    return;
                }

                const latestTime = data.timestamp[data.timestamp.length - 1];
                const closePrice = latestData.close[latestData.close.length - 1];

                // Veriyi listeye ekleyelim
                const listItem = document.createElement("li");
                listItem.className = "symbol-item";

                listItem.innerHTML = `
                    <strong>${symbol.description}</strong><br>
                    <span>Sembol: ${symbol.proName}</span><br>
                    <span>Son İşlem Zamanı: ${new Date(latestTime * 1000).toLocaleString()}</span><br>
                    <span>Kapanış Fiyatı: ${closePrice}</span>
                `;
                listContainer.appendChild(listItem);
            }).catch(error => {
                errorMessage.textContent = `Hata: ${error.message}`;
            });
        });
    }

    // Verileri çekip listeyi güncelle
    updateSymbolList(SYMBOLS);
</script>

</body>
</html>
